[
  {
    "name": "theme_info",
    "theme_name": "podcasts",
    "theme_label": "t:schema.theme_label",
    "theme_description": "t:schema.theme_description",
    "theme_version": "2.0.2",
    "theme_syntax_version": "v2",
    "theme_scope": "cms",
    "theme_author": "Baklib",
    "theme_documentation_url": "https://help.baklib.cn/themes",
    "theme_support_url": "https://help.baklib.cn/themes",
    "theme_thumb_url": "images/theme/thumb.png",
    "theme_preview_images": [
      "images/theme/release-guide.png",
      "images/theme/index-list.png",
      "images/theme/page.png"
    ],
    "theme_languages": [
      {
        "name": "中文简体",
        "value": "zh-CN"
      },
      {
        "name": "中文繁體",
        "value": "zh-TW"
      },
      {
        "name": "한국어",
        "value": "ko"
      },
      {
        "name": "English",
        "value": "en"
      },
      {
        "name": "日本語",
        "value": "ja"
      }
    ],
    "recommendations": {
      "color_schemas": {
        "fashion": {
          "name": "时尚",
          "colors": {
            "--theme-color-primary": "#3D50E0",
            "--theme-color-secondary": "#E91E63",
            "--theme-color-accent": "#AAAAAA",
            "--theme-color-info": "#2196F3",
            "--theme-color-success": "#4CAF50",
            "--theme-color-warning": "#FFC107"
          }
        },
        "old_school": {
          "name": "复古",
          "colors": {
            "--theme-color-primary": "#9C27B0",
            "--theme-color-secondary": "#673AB7",
            "--theme-color-accent": "#AAAAAA",
            "--theme-color-info": "#418CC8",
            "--theme-color-success": "#29B52F",
            "--theme-color-warning": "#FFC107"
          }
        }
      }
    }
  },
  {
    "name": "t:schema.podcast.name",
    "settings": [
      {
        "id": "poster_image_url",
        "type": "image_picker",
        "ratio": "1:1",
        "width": 200,
        "label": "t:schema.podcast.settings.poster_image_url.label"
      },
      {
        "id": "podcast_title",
        "type": "text",
        "label": "t:schema.podcast.settings.podcast_title.label"
      },
      {
        "id": "podcast_tagline",
        "type": "textarea",
        "label": "t:schema.podcast.settings.podcast_tagline.label"
      },
      {
        "id": "podcast_about",
        "type": "textarea",
        "to_markdown": true,
        "label": "t:schema.podcast.settings.podcast_about.label"
      },
      {
        "id": "show_episode_cover",
        "type": "checkbox",
        "label": "t:schema.podcast.settings.show_episode_cover.label",
        "default": false,
        "info": "t:schema.podcast.settings.show_episode_cover.info"
      },
      {
        "id": "header_html",
        "type": "html",
        "label": "t:schema.podcast.settings.header_html.label",
        "info": "t:schema.podcast.settings.header_html.info"
      }
    ]
  },
  {
    "name": "t:schema.custom_html.name",
    "settings": [
      {
        "id": "head_html",
        "type": "html",
        "label": "t:schema.custom_html.settings.head_html.label",
        "info": "t:schema.custom_html.settings.head_html.info",
        "rows": 10,
        "placeholder": "t:schema.custom_html.settings.head_html.placeholder"
      }
    ]
  }
]
