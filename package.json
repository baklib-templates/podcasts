{
  "name": "guide",
  "version": "2.0.1",
  "license": "MIT",
  "scripts": {
    "build": "npm-run-all --parallel build:css build:css:v2 build:js",
    "build:css": "npx @tailwindcss/cli -i ./src/stylesheets/application.css -o ./assets/stylesheets/application.css",
    "build:css:v2": "npx @tailwindcss/cli -i ./src/stylesheets/v2.css -o ./assets/stylesheets/v2.css",
    "build:js": "npx esbuild ./src/javascripts/application.js --bundle --minify --outfile=./assets/javascripts/application.js",
    "dev": "npm-run-all --parallel 'build:css --watch' 'build:css:v2 --watch' 'build:js --watch'",
    "livereload": "guard"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.4",
    "@tailwindcss/typography": "^0.5.16",
    "daisyui": "^5.5.19",
    "esbuild": "^0.19.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.4",
    "viewerjs": "^1.11.6"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo": "^8.0.23",
    "alpinejs": "^3.14.9"
  }
}
