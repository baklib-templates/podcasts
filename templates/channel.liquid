{%- comment -%}
  Channel page under a language root: `/<lang>/<channel>/`
  Lists children policies.
{%- endcomment -%}

{%- assign episodes = page.children_in_list | order_by: '-published_at' -%}

<div class="pt-16 pb-12 sm:pb-4 lg:pt-12">
  <div class="mx-auto px-4 sm:px-6 md:max-w-2xl md:px-4 lg:px-8 xl:px-12">
    <h1 class="text-2xl/7 font-bold text-slate-900">{{ page.link_text | presence | default: (site.settings.episodes_label | default: 'Episodes') }}</h1>
    {%- if page.settings.description -%}
      <p class="mt-2 text-base/7 text-slate-700">{{ page.settings.description }}</p>
    {%- endif -%}
  </div>

  <div class="divide-y divide-slate-100 sm:mt-4 lg:mt-8 lg:border-t lg:border-slate-100">
    {%- for ep in episodes -%}
      {% render 'transmit_episode_entry', page: ep %}
    {%- else -%}
      <div class="mx-auto px-4 py-16 text-sm text-slate-500 sm:px-6 md:max-w-2xl md:px-4 lg:px-8 xl:px-12">
        {{ 'generic.empty' | t }}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
  {
    "name": "t:schema.templates.channel.name",
    "thumb_url": "images/theme/index-card.png",
    "preview_image_urls": [
      "images/theme/index-card.png"
    ],
    "description": "t:schema.templates.channel.description",
    "sub_page_templates": ["page"],
    "settings": [
      {
        "id": "description",
        "type": "textarea",
        "to_markdown": true,
        "label": "t:schema.templates.channel.settings.description.label"
      }
    ]
  }
{% endschema %}

