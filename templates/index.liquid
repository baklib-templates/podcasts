{%- assign channels = site.pages['/'].children_in_list -%}
{%- assign current_channel = channels | first -%}
{%- assign episodes = current_channel.children_in_list | order_by: '-published_at' -%}

<div class="pt-16 pb-12 sm:pb-4 lg:pt-12">
  <div class="mx-auto px-4 sm:px-6 md:max-w-2xl md:px-4 lg:px-8 xl:px-12">
    <h1 class="text-2xl/7 font-bold text-slate-900">{{ site.settings.episodes_label | default: 'Episodes' }}</h1>

    {%- assign channels_size = channels | size -%}
    {%- if channels_size > 1 -%}
      <div class="mt-4 flex flex-wrap gap-3 text-sm/6 font-medium text-slate-600">
        {%- for ch in channels -%}
          <a href="{{ ch.path }}" class="hover:text-slate-900">{{ ch.link_text }}</a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="divide-y divide-slate-100 sm:mt-4 lg:mt-8 lg:border-t lg:border-slate-100">
    {%- for ep in episodes -%}
      {% render 'transmit_episode_entry', page: ep %}
    {%- else -%}
      <div class="mx-auto px-4 py-16 text-sm text-slate-500 sm:px-6 md:max-w-2xl md:px-4 lg:px-8 xl:px-12">
        {{ 'generic.empty' | t }}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
  {
    "name": "t:schema.templates.index_card.name",
    "description": "t:schema.templates.index_card.description",
    "thumb_url": "images/theme/index-card.png",
    "preview_image_urls": [
      "images/theme/index-card.png"
    ],
    "sub_page_templates": ["channel"]
  }
{% endschema %}
