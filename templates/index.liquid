{%- assign channels = site.pages['/'].children_in_list -%}
{%- assign episodes = site.pages | where: 'template_name', 'page' | order_by: '-edited_at' | limit: 12 -%}

<div class="py-8 lg:py-24">
  <div class="mx-auto px-4 sm:px-6 md:max-w-4xl md:px-4 lg:px-8 xl:px-12">
    <h1 class="text-2xl/7 font-bold text-slate-900">{{ 'podcast.episodes_heading' | t }}</h1>

    {%- assign channels_size = channels | size -%}
    {%- if channels_size > 1 -%}
      {% render 'channel_nav', channels: channels, home_channel_href: site.index_path %}
    {%- endif -%}
  </div>

  <div class="divide-y divide-slate-100 sm:mt-4 lg:mt-8 lg:border-t lg:border-slate-100">
    <div class="mx-auto max-w-4xl py-2 px-4 sm:px-6 md:max-w-4xl md:px-4 lg:px-8 xl:px-12">
      <h2 class="text-xl/7 font-bold text-slate-900">{{ 'podcast.recent_updates' | t }}</h2>
    </div>
    {%- for ep in episodes -%}
      {% render 'episode_entry', page: ep %}
    {%- else -%}
      <div class="mx-auto px-4 py-16 text-sm text-slate-500 sm:px-6 md:max-w-2xl md:px-4 lg:px-8 xl:px-12">
        {{ 'generic.empty' | t }}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
  {
    "name": "t:schema.templates.index_card.name",
    "description": "t:schema.templates.index_card.description",
    "thumb_url": "images/theme/index-card.png",
    "preview_image_urls": [
      "images/theme/index-card.png"
    ],
    "sub_page_templates": ["channel"]
  }
{% endschema %}
