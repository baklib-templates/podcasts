{% assign pages = site.pages['/'].children_in_list | order_by: '-created_at' %}

<div class="flex-1 bg-white">
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="mb-10 space-y-8 border-b border-slate-200 pb-10">
      {% form_tag 'search' %}
        <label class="relative flex max-w-2xl items-center rounded-xl border border-slate-200 bg-slate-50 transition-colors focus-within:border-slate-300 focus-within:bg-white">
          <span class="pointer-events-none absolute left-4 text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.3-4.3" />
            </svg>
          </span>
          <input
            type="search"
            name="{{ form.keywords_field_name }}"
            value="{{ search.keywords | escape_once }}"
            class="w-full rounded-xl border-0 bg-transparent py-3.5 pl-12 pr-4 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-0 md:text-base"
            placeholder="{{ 'generic.placeholders.search' | t }}"
            autocomplete="off"
          />
        </label>
      {% endform_tag %}

      {% assign tags_size = site.tags | size %}
      {% if tags_size > 0 %}
        <div class="-mx-1 min-w-0 overflow-x-auto px-1">
          <ul class="flex flex-nowrap gap-x-6 gap-y-2 text-sm font-medium md:gap-x-8">
            <li class="shrink-0">
              <span class="border-b-2 border-slate-900 pb-1 text-slate-900">{{ 'templates.index.list.all' | t }}</span>
            </li>
            {% for tag in site.tags %}
              <li class="shrink-0">
                <a href="{{ tag.path }}" class="border-b-2 border-transparent pb-1 text-slate-500 transition-colors hover:text-slate-900">
                  {{ tag.name }}
                </a>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    </div>

    {% paginate_tag pages, per: 9 %}
      <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm shadow-slate-900/[0.04]">
        {% for page in pages %}
          {% render 'list', page: page %}
        {% else %}
          <div class="px-6 py-24 text-center text-sm text-slate-500">{{ 'generic.empty' | t }}</div>
        {% endfor %}
      </div>

      {% if paginate.total_count > 0 %}
        <div class="mt-14 flex justify-center border-t border-slate-100 pt-10">
          {% render 'paginate', paginate: paginate %}
        </div>
      {% endif %}
    {% endpaginate_tag %}
  </div>
</div>

{% schema %}
  {
    "name": "t:schema.templates.index_list.name",
    "description": "t:schema.templates.index_list.description",
    "thumb_url": "images/theme/index-list.png",
    "preview_image_urls": [
      "images/theme/index-list.png"
    ],
    "sub_page_templates": ["page"]
  }
{% endschema %}
