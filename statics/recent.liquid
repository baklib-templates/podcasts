{% layout false %}
{% assign pages = site.pages['/'].children_in_list | order_by: '-created_at' | limit: 5 %}

<!DOCTYPE html>
<html class="scroll-smooth bg-slate-50" lang="{{ site.language }}">
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="author" content="Baklib">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% meta_tags %}
    {{ 'stylesheets/application.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'baklib/shared/main.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'baklib/shared/main.js' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'javascripts/application.js' | asset_url | script_tag: defer: true, data-turbo-track: 'reload' }}
    {% if false %} {{ 'javascripts/cdn.tailwindcss.js' | asset_url | script_tag: data-turbo-track: 'reload' }} {% endif %}
    {{ site.settings.head_html }}
  </head>

  <body class="min-h-screen antialiased text-slate-600">
    <div class="mx-auto min-h-screen max-w-3xl px-4 py-8 sm:px-6 lg:max-w-4xl lg:py-12">
      <header class="mb-10 border-b border-slate-200 pb-8">
        <a
          href="{{ site.index_path }}"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 transition-colors hover:text-slate-900"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="m15 18-6-6 6-6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          {{ 'generic.back_to_home' | t }}
        </a>
        <h1 class="mt-6 text-2xl font-semibold tracking-tight text-slate-900 md:text-3xl">
          {{ 'generic.recent_updates' | t }}
        </h1>
        <p class="mt-2 text-sm text-slate-500">
          {{ 'generic.recent_memo_note' | t }}
        </p>
      </header>

      <div class="space-y-4">
        {% for page in pages %}
          {% assign display_tags = page.settings.tags %}
          {% assign display_tags_size = display_tags | size %}
          {% if display_tags_size == 0 %}
            {% assign display_tags = page.tags %}
          {% endif %}

          {% assign thumb_image_url = page.settings.thumb_image_url | presence %}
          <article class="overflow-hidden rounded-2xl border border-slate-200 bg-white p-4 shadow-sm shadow-slate-900/[0.04] sm:p-5">
            <div class="flex flex-col gap-4 sm:flex-row sm:gap-5">
              <a
                href="{{ page.path }}"
                class="group/thumb relative block shrink-0 overflow-hidden rounded-xl border border-slate-100 bg-slate-100 sm:w-40 sm:self-start aspect-[16/10] sm:aspect-[4/3] sm:h-28"
                aria-hidden="true"
                tabindex="-1"
              >
                {% if thumb_image_url %}
                  <img
                    src="{{ thumb_image_url }}"
                    alt=""
                    class="h-full w-full object-cover transition duration-300 group-hover/thumb:scale-[1.03]"
                    loading="lazy"
                  />
                {% else %}
                  <div class="flex h-full w-full items-center justify-center text-slate-400">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="h-10 w-10">
                      <rect x="3" y="5" width="18" height="14" rx="2" />
                      <circle cx="8.5" cy="10" r="1.5" />
                      <path d="M21 17l-6-6-4 4-2-2-4 4" />
                    </svg>
                  </div>
                {% endif %}
              </a>

              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2 text-xs text-slate-500">
                  {% if page.published_at %}
                    <time datetime="{{ page.published_at | date: '%Y-%m-%d' }}" class="inline-flex items-center gap-1 font-mono text-slate-500">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-3.5 w-3.5 shrink-0" fill="currentColor" aria-hidden="true">
                        <path d="M7 3V1H9V3H15V1H17V3H21C21.5523 3 22 3.44772 22 4V9H20V5H17V7H15V5H9V7H7V5H4V19H10V21H3C2.44772 21 2 20.5523 2 20V4C2 3.44772 2.44772 3 3 3H7ZM17 12C14.7909 12 13 13.7909 13 16C13 18.2091 14.7909 20 17 20C19.2091 20 21 18.2091 21 16C21 13.7909 19.2091 12 17 12ZM11 16C11 12.6863 13.6863 10 17 10C20.3137 10 23 12.6863 23 16C23 19.3137 20.3137 22 17 22C13.6863 22 11 19.3137 11 16ZM16 13V16.4142L18.2929 18.7071L19.7071 17.2929L18 15.5858V13H16Z" />
                      </svg>
                      {{ page.published_at | date: "%Y-%m-%d" }}
                    </time>
                  {% endif %}

                  {% for tag in display_tags %}
                    <a
                      href="{{ tag.path }}"
                      class="rounded-full bg-slate-100 px-2 py-0.5 text-[11px] font-medium text-slate-700 transition-colors hover:bg-slate-200"
                    >
                      {{ tag.name }}
                    </a>
                  {% endfor %}
                </div>

                <h2 class="mt-3 text-lg font-semibold leading-snug tracking-tight text-slate-900">
                  <a href="{{ page.path }}" class="transition-colors hover:text-slate-600">{{ page.link_text }}</a>
                </h2>

                {% if page.settings.description %}
                  <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-slate-500">
                    {{ page.settings.description | strip_html }}
                  </p>
                {% endif %}

                {% render 'sub_page_list', page: page, per: 5 %}
              </div>
            </div>
          </article>
        {% else %}
          <div class="rounded-2xl border border-dashed border-slate-200 bg-white px-6 py-16 text-center text-sm text-slate-500">
            {{ 'generic.empty' | t }}
          </div>
        {% endfor %}
      </div>
    </div>
  </body>
</html>
