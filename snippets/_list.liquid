{% comment %} List row for index.list — aligned with card/search typography {% endcomment %}
{% assign page_thumb_image_url = page.settings.thumb_image_url | presence %}
<article class="flex gap-4 border-b border-slate-100 px-4 py-6 transition-colors last:border-b-0 hover:bg-slate-50/80 sm:gap-6 sm:px-6 md:py-7">
  <div class="min-w-0 flex-1">
    <a href="{{ page.path }}" class="group block">
      <h2 class="text-lg font-semibold leading-snug tracking-tight text-slate-900 group-hover:text-slate-600 md:text-xl">
        {{ page.link_text }}
      </h2>
      {% if page.settings.description %}
        <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-slate-500 md:text-[15px]">
          {{ page.settings.description }}
        </p>
      {% endif %}
    </a>

    {% assign tag_count = page.tags | size %}
    {% if tag_count > 0 %}
      <ul class="mt-3 flex flex-wrap gap-2">
        {% for tag in page.tags %}
          <li>
            <a
              href="{{ tag.path }}"
              class="inline-flex rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-700 transition-colors hover:bg-slate-200"
            >
              {{ tag.name }}
            </a>
          </li>
        {% endfor %}
      </ul>
    {% endif %}

    {% render 'sub_page_list', page: page, per: 5 %}
  </div>

  {% if page_thumb_image_url %}
    <a href="{{ page.path }}" class="group/thumb relative shrink-0" aria-hidden="true" tabindex="-1">
      <span class="block h-20 w-28 overflow-hidden rounded-xl border border-slate-100 bg-slate-100 sm:h-24 sm:w-36">
        <img
          src="{{ page_thumb_image_url }}"
          alt=""
          class="h-full w-full object-cover transition duration-300 group-hover/thumb:scale-[1.03]"
          loading="lazy"
        />
      </span>
    </a>
  {% endif %}
</article>
