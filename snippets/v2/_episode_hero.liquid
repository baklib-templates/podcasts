{%- comment -%}
  @param episode_title, episode_display_title, episode_description, episode_thumb_image_url
  @param episode_audio_src, episode_audio_type, published_at, page
{%- endcomment -%}

{%- assign default_poster = 'images/poster.png' | asset_url -%}
{%- assign hero_cover = episode_thumb_image_url | default: site.settings.poster_image_url | default: default_poster -%}
{%- assign parent_channel = page.parent -%}
{%- assign back_href = parent_channel.path | default: site.index_path -%}

<section class="border-b border-base-300 bg-base-100 px-6 py-4">
  <div class="mx-auto max-w-3xl">
    {% render 'v2/page_toolbar', back_href: back_href, show_actions: true %}

    <div class="mt-6 flex flex-col gap-6 sm:flex-row sm:items-start">
      <img
        src="{{ hero_cover }}"
        alt=""
        class="h-48 w-48 shrink-0 rounded-xl object-cover ring-1 ring-base-content/10 sm:h-56 sm:w-56"
        loading="eager"
      />
      <div class="min-w-0 flex-1">
        {%- if published_at -%}
          <time datetime="{{ published_at | date: '%Y-%m-%d' }}" class="text-sm text-base-content/55">
            {{ published_at | date: '%B %e, %Y' }}
          </time>
        {%- endif -%}
        <h1 class="mt-2 text-2xl font-bold tracking-tight text-base-content sm:text-3xl">{{ episode_display_title }}</h1>

        {%- if parent_channel -%}
          <a
            href="{{ parent_channel.path }}"
            data-turbo-frame="main-content-frame"
            data-turbo-action="advance"
            class="mt-2 inline-flex items-center gap-1 text-sm font-medium text-primary hover:opacity-80"
          >
            {{ parent_channel.link_text }}
            <span aria-hidden="true">›</span>
          </a>
        {%- endif -%}

        {%- if episode_description -%}
          <p class="mt-3 text-base leading-relaxed text-base-content/75">{{ episode_description }}</p>
        {%- endif -%}

        <div class="mt-5 flex flex-wrap items-center gap-3">
          <button
            type="button"
            class="v2-pill-btn-primary min-w-[8rem]"
            @click="$store.player.toggle({ id: '{{ page.id }}', title: '{{ episode_display_title | escape_once }}', path: '{{ page.path | escape_once }}', audioSrc: '{{ episode_audio_src | escape_once }}', audioType: '{{ episode_audio_type | default: '' | escape_once }}' })"
          >
            <span aria-hidden="true">▶</span>
            {{ 'podcast.listen' | t }}
          </button>
          <button type="button" class="v2-icon-btn opacity-40" disabled aria-label="{{ 'podcast.v2.download' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4" aria-hidden="true">
              <path d="M12 3v12m0 0 4-4m-4 4-4-4M4 21h16" />
            </svg>
          </button>
          <button type="button" class="v2-icon-btn opacity-40" disabled aria-hidden="true">
            <span>⋯</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
