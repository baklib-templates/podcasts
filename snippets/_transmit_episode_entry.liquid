{%- assign episode = page -%}
{%- assign episode_title = episode.link_text | presence -%}
{%- assign episode_description = episode.settings.description | presence -%}
{%- assign episode_audio_src = episode.settings.audio_src | presence -%}
{%- assign episode_audio_type = episode.settings.audio_type | presence -%}
{%- assign episode_number = episode.settings.episode_number | presence -%}
{%- assign episode_display_title = episode_title -%}
{%- if episode_number -%}
  {%- capture episode_display_title -%}{{ episode_number }}: {{ episode_title }}{%- endcapture -%}
{%- endif -%}

{%- assign published_at = episode.published_at | default: episode.created_at -%}

<article aria-labelledby="episode-{{ episode.id }}-title" class="py-10 sm:py-12">
  <div class="mx-auto px-4 sm:px-6 md:max-w-2xl md:px-4 lg:px-8 xl:px-12">
    <div class="flex flex-col items-start">
      <h2 id="episode-{{ episode.id }}-title" class="mt-2 text-lg font-bold text-slate-900">
        <a href="{{ episode.path }}">{{ episode_display_title }}</a>
      </h2>

      {%- if published_at -%}
        <time datetime="{{ published_at | date: '%Y-%m-%d' }}" class="order-first font-mono text-sm/7 text-slate-500">
          {{ published_at | date: '%B %e, %Y' }}
        </time>
      {%- endif -%}

      {%- if episode_description -%}
        <p class="mt-1 text-base/7 text-slate-700">{{ episode_description }}</p>
      {%- endif -%}

      <div class="mt-4 flex items-center gap-4">
        <button
          type="button"
          class="flex items-center gap-x-3 text-sm/6 font-bold text-pink-500 hover:text-pink-700 active:text-pink-900"
          x-data
          @click="$store.player.toggle({ id: '{{ episode.id }}', title: {{ episode_display_title | json }}, path: '{{ episode.path }}', audioSrc: {{ episode_audio_src | default: '' | json }}, audioType: {{ episode_audio_type | default: '' | json }} })"
          :aria-label="($store.player.playing && $store.player.episode && $store.player.episode.id === '{{ episode.id }}') ? 'Pause episode' : 'Play episode'"
        >
          <span
            class="inline-flex h-2.5 w-2.5 items-center justify-center"
            aria-hidden="true"
          >
            <span x-show="$store.player.playing && $store.player.episode && $store.player.episode.id === '{{ episode.id }}'">❚❚</span>
            <span x-show="!($store.player.playing && $store.player.episode && $store.player.episode.id === '{{ episode.id }}')">▶</span>
          </span>
          <span aria-hidden="true">{{ site.settings.listen_label | default: 'Listen' }}</span>
        </button>

        <span aria-hidden="true" class="text-sm font-bold text-slate-400">/</span>

        <a
          href="{{ episode.path }}"
          class="flex items-center text-sm/6 font-bold text-pink-500 hover:text-pink-700 active:text-pink-900"
          aria-label="Show notes for episode {{ episode_display_title | escape }}"
        >
          {{ site.settings.show_notes_label | default: 'Show notes' }}
        </a>
      </div>
    </div>
  </div>
</article>

