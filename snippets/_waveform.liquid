{%- comment -%}
  Decorative waveform background. Gradient uses site theme semantic colors
  (--theme-color-* from {% meta_tags %}). IDs are unique per page to avoid SVG defs collisions.
{%- endcomment -%}

{%- assign waveform_seed = page.id | default: 'site' -%}
{%- capture waveform_id -%}waveform-{{ waveform_seed }}{%- endcapture -%}

<svg aria-hidden="true" class="{{ class | default: '' }}" viewBox="0 0 1200 80" preserveAspectRatio="none">
  <defs>
    <linearGradient id="{{ waveform_id }}-fade" x1="0" x2="0" y1="0" y2="1">
      <stop offset="40%" stop-color="hsl(var(--theme-color-base-100))" />
      <stop offset="100%" stop-color="hsl(var(--theme-color-base-content))" />
    </linearGradient>
    <linearGradient id="{{ waveform_id }}-gradient" x1="0" x2="1" y1="0" y2="0">
      <stop offset="0%" stop-color="hsl(var(--theme-color-info))" />
      <stop offset="25%" stop-color="hsl(var(--theme-color-primary))" />
      <stop offset="50%" stop-color="hsl(var(--theme-color-secondary))" />
      <stop offset="75%" stop-color="hsl(var(--theme-color-accent))" />
      <stop offset="100%" stop-color="hsl(var(--theme-color-neutral))" />
    </linearGradient>
    <pattern id="{{ waveform_id }}-pattern" width="4" height="80" patternUnits="userSpaceOnUse">
      <rect x="2" y="0" width="2" height="80" fill="url(#{{ waveform_id }}-fade)" opacity="0.9" />
    </pattern>
    <mask id="{{ waveform_id }}-mask">
      <rect width="100%" height="100%" fill="url(#{{ waveform_id }}-pattern)" />
    </mask>
  </defs>
  <rect width="100%" height="100%" fill="url(#{{ waveform_id }}-gradient)" mask="url(#{{ waveform_id }}-mask)" opacity="0.25" />
</svg>

