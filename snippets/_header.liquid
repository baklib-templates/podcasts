<header
  class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/95 text-slate-900 backdrop-blur supports-[backdrop-filter]:bg-white/80"
>
  <div class="mx-auto flex max-w-7xl items-center gap-3 px-4 py-3 md:gap-6">
    {% assign logo = 'images/logo.png' | asset_url %}

    <a href="{{ site.index_path }}" class="flex min-w-0 flex-1 items-center gap-2 md:flex-none md:max-w-[min(50%,20rem)] md:gap-3">
      <span class="flex h-9 w-9 shrink-0 items-center justify-center overflow-hidden rounded-full border border-slate-200 bg-slate-50">
        <img
          src="{{ site.favicon_url | default: logo }}"
          alt=""
          class="h-full w-full object-cover"
          onerror="this.onerror=null;this.src='{{ logo }}';"
        />
      </span>
      <span class="min-w-0 truncate text-base font-semibold tracking-tight text-slate-900 md:text-lg">{{ site.name }}</span>
    </a>

    <div class="shrink-0 md:hidden">
      {% render 'header_drawer' %}
    </div>

    <div class="hidden min-w-0 flex-1 items-center justify-end gap-6 md:flex">
      <nav
        aria-label="Primary"
        class="flex min-w-0 flex-wrap items-center justify-end gap-x-3 gap-y-1 [&_a]:text-sm [&_a]:font-medium [&_a]:text-slate-600 [&_a]:transition-colors [&_a]:hover:text-slate-900 md:gap-x-4"
      >
        {{ site.settings.header_menu_html }}
      </nav>

      {% if site.search_path or current_user %}
        <div class="flex shrink-0 items-center gap-4 border-l border-slate-200 pl-6">
          {% if site.search_path %}
            <a
              href="{{ site.search_path }}"
              class="flex h-9 w-9 items-center justify-center rounded-md text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900"
              aria-label="{{ 'generic.placeholders.search' | t }}"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.3-4.3" />
              </svg>
            </a>
          {% endif %}

          {% if current_user %}
            <div class="dropdown dropdown-end">
              <div tabindex="0" role="button" class="avatar flex h-9 w-9 cursor-pointer items-center justify-center rounded-full bg-slate-100 ring-1 ring-slate-200">
                {% if current_user.image %}
                  <img src="{{ current_user.image }}" alt="" class="h-9 w-9 rounded-full object-cover" />
                {% else %}
                  <svg class="h-5 w-5 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="8" r="4" />
                    <path d="M4 20c0-4 8-4 8-4s8 0 8 4" />
                  </svg>
                {% endif %}
              </div>
              <div tabindex="0" class="dropdown-content mt-2 w-44 space-y-2 rounded-box border border-slate-200 bg-white py-2 px-3 shadow-lg">
                <div class="line-clamp-1 border-b border-slate-100 pb-2 text-sm font-medium text-slate-800">{{ current_user.name }}</div>
                <div class="text-slate-600">
                  {% form_tag 'sign_out' %}
                    <button type="submit" class="hover:link w-full text-left text-sm">{{ 'generic.buttons.signout' | t }}</button>
                  {% endform_tag %}
                </div>
              </div>
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</header>
