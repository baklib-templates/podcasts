{%- comment -%}
  @param paginate - paginate object from paginate_tag block
{%- endcomment -%}

{%- if paginate.total_count > 0 -%}
  <div class="mx-auto px-4 py-10 sm:px-6 md:max-w-4xl md:px-4 lg:px-8 xl:px-12">
    {%- if paginate.total_pages > 1 -%}
      <nav class="flex flex-col items-center gap-4" aria-label="Pagination">
        <div class="flex items-center gap-1">
          {%- if paginate.prev_page -%}
            <a
              href="{{ paginate.url_for[paginate.prev_page] }}"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
              class="inline-flex items-center gap-1 rounded-lg border border-base-300 bg-base-100 px-3 py-2 text-sm font-semibold text-base-content hover:border-primary/30 hover:text-primary"
            >
              {{ 'paginate.previous' | t }}
            </a>
          {%- else -%}
            <span class="inline-flex cursor-not-allowed items-center gap-1 rounded-lg border border-base-300/60 bg-base-200/50 px-3 py-2 text-sm font-semibold text-base-content/40">
              {{ 'paginate.previous' | t }}
            </span>
          {%- endif -%}

          <div class="hidden items-center gap-1 sm:flex">
            {%- for i in paginate.series -%}
              {%- assign series_type = i | typeof -%}
              {%- if series_type == 'string' -%}
                {%- if i == 'gap' -%}
                  <span class="px-2 text-sm text-base-content/45">…</span>
                {%- else -%}
                  <span class="inline-flex min-w-9 items-center justify-center rounded-lg bg-primary px-3 py-2 text-sm font-semibold text-primary-content" aria-current="page">{{ i }}</span>
                {%- endif -%}
              {%- elsif series_type == 'integer' -%}
                <a
                  href="{{ paginate.url_for[i] }}"
                  data-turbo-frame="main-content-frame"
                  data-turbo-action="advance"
                  class="inline-flex min-w-9 items-center justify-center rounded-lg px-3 py-2 text-sm font-semibold text-base-content/80 hover:bg-base-200 hover:text-primary"
                >
                  {{ i }}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- if paginate.next_page -%}
            <a
              href="{{ paginate.url_for[paginate.next_page] }}"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
              class="inline-flex items-center gap-1 rounded-lg border border-base-300 bg-base-100 px-3 py-2 text-sm font-semibold text-base-content hover:border-primary/30 hover:text-primary"
            >
              {{ 'paginate.next' | t }}
            </a>
          {%- else -%}
            <span class="inline-flex cursor-not-allowed items-center gap-1 rounded-lg border border-base-300/60 bg-base-200/50 px-3 py-2 text-sm font-semibold text-base-content/40">
              {{ 'paginate.next' | t }}
            </span>
          {%- endif -%}
        </div>

        <p class="text-center text-sm text-base-content/60">
          {{ 'paginate.showing' | t }}
          <span class="font-semibold text-base-content">{{ paginate.from }}–{{ paginate.to }}</span>
          {{ 'paginate.total' | t }}
          <span class="font-semibold text-base-content">{{ paginate.total_count }}</span>
          {{ 'paginate.records' | t }}
        </p>
      </nav>
    {%- else -%}
      <p class="text-center text-sm text-base-content/60">
        {{ 'paginate.total' | t }}
        <span class="font-semibold text-base-content">{{ paginate.total_count }}</span>
        {{ 'paginate.records' | t }}
      </p>
    {%- endif -%}
  </div>
{%- endif -%}
